{# templates/auction/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ auction.name }} - Enchère{% endblock %}

{% block body %}
    {# Configuration pour JavaScript #}
    <div id="auction-config"
         data-subscription-token="{{ subscriptionToken|escape('js') }}"
         data-mercure-url="{{ mercureUrl }}"
         data-auction-id="{{ auction.id }}"
         data-minimum-increment="{{ minimumIncrement }}"
         data-minimum-next-bid="{{ minimumNextBid }}"
         data-user-id="{{ userId }}"
         style="display: none;">
    </div>

    <div class="container mx-auto px-4 py-8">
        <div class="max-w-4xl mx-auto">
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
                <!-- Section Image et Infos Célébrité -->
                <div class="relative">
                    <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-[#1D365B] to-transparent">
                        <div class="flex items-center">
                            <div class="ml-4">
                                <h1 class="text-2xl text-white font-bold">{{ auction.celebrity.stageName }}</h1>
                                <p class="golden-text">{{ auction.celebrity.profession.name }}</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Informations de l'enchère -->
                <div class="p-6">
                    <h2 class="text-3xl font-bold text-[#1D365B] mb-4">{{ auction.name }}</h2>
                    <p class="text-[#234B6E] mb-8">{{ auction.description }}</p>

                    <!-- État actuel de l'enchère -->
                    <div class="bg-gray-50 rounded-xl p-6 mb-8">
                        <div class="grid grid-cols-2 gap-8">
                            <div>
                                <p class="text-sm text-[#234B6E]">Enchère actuelle</p>
                                <p class="text-3xl font-bold golden-text" id="current-bid">
                                    {{ highestBid|number_format(2, ',', ' ') }} €
                                </p>
                                <p class="text-sm text-[#234B6E] mt-2" id="last-bidder">
                                    {% if auction.products[0].bids is not empty %}
                                        Dernière enchère par {{ auction.products[0].bids|last.bidder.email }}
                                    {% endif %}
                                </p>
                            </div>
                            <div>
                                <p class="text-sm text-[#234B6E]">Temps restant</p>
                                <p class="text-3xl font-bold text-[#1D365B]"
                                   data-countdown="{{ auction.finishedAt|date('Y-m-d H:i:s') }}"
                                   id="countdown">
                                    --:--:--
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Formulaire d'enchère -->
                    {% if is_granted('ROLE_USER') and auction.status == 'active' %}
                        <div class="mt-8">
                            <form id="auction-form" class="space-y-6">
                                <div class="space-y-2">
                                    <label for="bid-amount" class="block text-sm font-medium text-[#234B6E]">
                                        Votre enchère (minimum {{ minimumNextBid|number_format(2, ',', ' ') }} €)
                                    </label>
                                    <div class="relative">
                                        <input type="number"
                                               id="bid-amount"
                                               name="amount"
                                               step="{{ minimumIncrement }}"
                                               min="{{ minimumNextBid }}"
                                               value="{{ minimumNextBid }}"
                                               class="w-full pl-4 pr-12 py-3 rounded-xl border border-[#E8C98B] text-[#1D365B] focus:outline-none focus:ring-2 focus:ring-[#D4B054]">
                                        <span class="absolute right-4 top-1/2 transform -translate-y-1/2 text-[#234B6E]">€</span>
                                    </div>
                                    <p class="text-sm text-[#234B6E]">
                                        Incrément minimum de {{ minimumIncrement }}€
                                    </p>
                                </div>
                                <button type="submit"
                                        class="btn-primary w-full bg-[#1D365B] text-white py-4 rounded-xl hover:bg-[#234B6E] transition-colors flex items-center justify-center">
                                    <span class="text-center font-semibold">Placer mon enchère</span>
                                </button>
                            </form>
                        </div>
                    {% elseif not is_granted('ROLE_USER') %}
                        <div class="text-center p-6 bg-gray-50 rounded-xl">
                            <p class="text-[#234B6E]">Connectez-vous pour participer à l'enchère</p>
                            <a href="{{ path('app_login') }}" class="bg-[#1D365B] text-white px-6 py-2 rounded-xl inline-block mt-4 hover:bg-[#234B6E] transition-colors">
                                Se connecter
                            </a>
                        </div>
                    {% elseif auction.status == 'finished' %}
                        <div class="text-center p-6 bg-gray-50 rounded-xl">
                            <p class="text-[#234B6E]">Cette enchère est terminée depuis le {{ auction.finishedAt|date('d/m/Y à H:i') }}</p>
                        </div>
                    {% elseif auction.status == 'upcoming' %}
                        <div class="text-center p-6 bg-gray-50 rounded-xl">
                            <p class="text-[#234B6E]">Cette enchère débutera le {{ auction.startedAt|date('d/m/Y à H:i') }}</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Récupération de la configuration
            const config = document.getElementById('auction-config');
            if (!config) {
                console.error('Configuration élément non trouvé');
                return;
            }

            // Configuration initiale
            const auctionId = config.dataset.auctionId;
            const minimumIncrement = parseFloat(config.dataset.minimumIncrement);
            const mercureUrl = config.dataset.mercureUrl;
            const userId = config.dataset.userId;
            const subscriptionToken = config.dataset.subscriptionToken;

            console.log('Configuration chargée:', {
                auctionId,
                minimumIncrement,
                mercureUrl
            });

            // Elements du DOM
            const currentBidElement = document.getElementById('current-bid');
            const lastBidderElement = document.getElementById('last-bidder');
            const bidInput = document.getElementById('bid-amount');
            const auctionForm = document.getElementById('auction-form');
            const countdownElement = document.getElementById('countdown');

            // Formateur de monnaie
            const currencyFormatter = new Intl.NumberFormat('fr-FR', {
                style: 'currency',
                currency: 'EUR',
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });

            // Fonction pour obtenir un nouveau token JWT
            async function getNewJwtToken() {
                try {
                    const response = await fetch('/api/token');
                    const data = await response.json();

                    if (data && data.token) {
                        console.log('Nouveau token JWT récupéré:', data.token);
                        return data.token;
                    } else {
                        console.error('Token JWT non trouvé dans la réponse:', data);
                        return null;
                    }
                } catch (error) {
                    console.error('Erreur lors de la récupération du nouveau token JWT:', error);
                    return null;
                }
            }

            // Fonction d'initialisation de Mercure
            function initializeMercure() {
                const url = new URL(mercureUrl);
                const topic = 'auction/' + auctionId;  // Format identique
                url.searchParams.append('topic', topic);

                console.log('Configuration Mercure:', {
                    url: url.toString(),
                    topic: topic
                });

                if (window.eventSource) {
                    window.eventSource.close();
                }

                window.eventSource = new EventSource(url.toString(), {
                    withCredentials: false
                });

                window.eventSource.addEventListener('message', (e) => {
                    console.log('Message reçu sur le topic:', topic);
                    console.log('Message contenu:', e.data);
                    try {
                        const data = JSON.parse(e.data);
                        updateAuctionDisplay(data);
                    } catch (error) {
                        console.error('Erreur parsing:', error);
                    }
                });
            }

// Nettoyage à la fermeture
            window.addEventListener('beforeunload', () => {
                if (window.eventSource) {
                    window.eventSource.close();
                }
            });

// Initialisation au chargement
            document.addEventListener('DOMContentLoaded', () => {
                console.log('Initialisation Mercure...');
                initializeMercure();
            });

// S'assurer que la connexion est fermée quand on quitte la page
            window.addEventListener('beforeunload', () => {
                if (window.eventSource) {
                    window.eventSource.close();
                }
            });

// Initialiser la connexion au chargement
            document.addEventListener('DOMContentLoaded', () => {
                initializeMercure();
            });


            // Mise à jour de l'affichage
            function updateAuctionDisplay(data) {
                console.log('updateAuctionDisplay appelé avec:', data);

                const bidData = data.data || data;
                console.log('Données à utiliser:', bidData);

                if (currentBidElement && bidData.highestBid) {
                    currentBidElement.textContent = currencyFormatter.format(parseFloat(bidData.highestBid));
                }

                if (lastBidderElement && bidData.bidder) {
                    lastBidderElement.textContent = `Dernière enchère par ${bidData.bidder}`;
                }

                if (bidInput && bidData.minimumBid) {
                    const minBid = parseFloat(bidData.minimumBid);
                    bidInput.min = minBid;
                    bidInput.value = minBid;

                    const label = bidInput.parentElement.previousElementSibling;
                    if (label) {
                        label.textContent = `Votre enchère (minimum ${currencyFormatter.format(minBid)})`;
                    }
                }
            }

            // Envoi d'une enchère
            async function placeBid(amount) {
                try {
                    const response = await fetch(`/api/auction/${auctionId}/bid`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({ amount: parseFloat(amount) })
                    });

                    const result = await response.json();
                    if (!response.ok) {
                        throw new Error(result.error || 'Une erreur est survenue');
                    }

                    if (result.data) {
                        updateAuctionDisplay(result);
                    }

                    return result;
                } catch (error) {
                    console.error('Erreur lors de l\'enchère:', error);
                    throw error;
                }
            }

            // Gestion du compte à rebours
            function initializeCountdown() {
                if (!countdownElement) return;

                function updateCountdown() {
                    const endTime = new Date(countdownElement.dataset.countdown).getTime();
                    const now = new Date().getTime();
                    const distance = endTime - now;

                    if (distance < 0) {
                        countdownElement.textContent = 'Terminée';
                        if (auctionForm) {
                            const message = document.createElement('div');
                            message.className = 'text-center p-6 bg-gray-50 rounded-xl';
                            message.innerHTML = '<p class="text-[#234B6E]">Cette enchère est terminée</p>';
                            auctionForm.replaceWith(message);
                        }
                        return false;
                    }

                    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                    countdownElement.textContent =
                        `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;

                    return true;
                }

                if (updateCountdown()) {
                    setInterval(updateCountdown, 1000);
                }
            }

            // Initialisation du formulaire
            if (auctionForm) {
                auctionForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const submitButton = e.target.querySelector('button[type="submit"]');
                    submitButton.disabled = true;

                    try {
                        const amount = parseFloat(bidInput.value);
                        const result = await placeBid(amount);
                        console.log('Enchère réussie:', result);
                    } catch (error) {
                        alert(error.message);
                    } finally {
                        submitButton.disabled = false;
                    }
                });
            }

            // Initialisation
            console.log('Démarrage de l\'application...');
            initializeMercure();
            initializeCountdown();
        });


    </script>
{% endblock %}