{# templates/base_admin.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Administration{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-gray-100">
<!-- Bouton burger pour mobile -->
<button
        onclick="toggleSidebar()"
        class="fixed top-4 left-4 z-50 md:hidden bg-[#5693a8] hover:bg-[#4a7f91] text-white p-2 rounded-lg transition-colors duration-300">
    <i class="fas fa-bars" id="menuIcon"></i>
</button>

<!-- Backdrop -->
<div
        onclick="toggleSidebar()"
        class="fixed inset-0 bg-black/50 z-30 md:hidden hidden transition-opacity duration-300"
        id="backdrop">
</div>

<!-- Sidebar -->
<div class="flex min-h-screen">
    <aside class="fixed top-0 left-0 h-screen w-72 shadow-lg bg-custom-gradient  transform -translate-x-full md:translate-x-0 transition-transform duration-300 z-40 overflow-y-auto" id="sidebar">
        <!-- Logo/Brand -->
        <a href="" class="flex items-center justify-center p-4 bg-[#234B6E]">
            <img src="{{ asset('img/3eos-logo.png') }}" alt="3EOS Logo" class="h-12 w-12 object-cover">
            <span class="ml-3 text-xl font-bold text-white tracking-wider">Administration</span>
        </a>

        <!-- Menu principal -->
        <div class="px-4 py-2 text-xs font-semibold text-[#1D365B]  uppercase tracking-wider">
            Menu principal
        </div>

        <nav class="px-2 py-3">
            <a href=""
               class="flex items-center px-4 py-3 text-[#1D365B]  hover:bg-white/30 rounded-lg transition-colors duration-200 {% if app.request.get('_route') == 'admin_dashboard' %}bg-white/20{% endif %}">
                <i class="fas fa-home w-5"></i>
                <span class="ml-3">Tableau de bord</span>
            </a>

            <a href="{{ path("admin_user_index") }}"
               class="flex items-center px-4 py-3 text-[#1D365B] hover:bg-white/10 rounded-lg transition-colors duration-200 {% if app.request.get('_route') == 'admin_user_index' %}bg-white/20{% endif %}">
                <i class="fas fa-users w-5"></i>
                <span class="ml-3">Utilisateurs</span>
            </a>

            <a href=""
               class="flex items-center px-4 py-3 text-[#1D365B]  hover:bg-white/10 rounded-lg transition-colors duration-200 {% if app.request.get('_route') == 'admin_quote' %}bg-white/20{% endif %}">
                <i class="fas fa-gavel"></i>
                <span class="ml-3">Enchères</span>
            </a>

            <a href=""
               class="flex items-center px-4 py-3 text-[#1D365B]  hover:bg-white/10 rounded-lg transition-colors duration-200 {% if app.request.get('_route') == 'admin_reservation' %}bg-white/20{% endif %}">
                <i class="fa-brands fa-product-hunt"></i>
                <span class="ml-3">Produits</span>
            </a>

            <a href=""
               class="flex items-center px-4 py-3 text-[#1D365B]  hover:bg-white/10 rounded-lg transition-colors duration-200 {% if app.request.get('_route') == 'admin_contact' %}bg-white/20{% endif %}">
                <i class="fas fa-file-invoice"></i>
                <span class="ml-3">Commandes</span>
            </a>

            <a href=""
               class="flex items-center px-4 py-3 text-[#1D365B]  hover:bg-white/10 rounded-lg transition-colors duration-200 {% if app.request.get('_route') == 'admin_review' %}bg-white/20{% endif %}">
                <i class="fas fa-comments w-5"></i>
                <span class="ml-3">Commentaires</span>
            </a>

            {#            <a href=""#}
            {#               class="flex items-center px-4 py-3 text-white hover:bg-white/10 rounded-lg transition-colors duration-200 {% if app.request.get('_route') == 'admin_intervenant' %}bg-white/20{% endif %}">#}
            {#                <i class="fas fa-user-tie w-5"></i>#}
            {#                <span class="ml-3">Intervenants</span>#}
            {#            </a>#}

            <hr class="my-4 border-white/20">

            <a href="{{ path('app_home') }}" class="flex items-center px-4 py-3 text-[#1D365B]  hover:bg-white/10 rounded-lg transition-colors duration-200">
                <i class="fas fa-laptop w-5"></i>
                <span class="ml-3">Aller sur le site</span>
            </a>

            <a href="{{ path('app_logout') }}" class="flex items-center px-4 py-3 text-[#1D365B]  hover:bg-white/10 rounded-lg transition-colors duration-200">
                <i class="fas fa-arrow-right-from-bracket w-5"></i>
                <span class="ml-3">Déconnexion</span>
            </a>
        </nav>
    </aside>

    <!-- Contenu principal -->
    <main class="flex-1 ml-0 md:ml-72 p-8 transition-all duration-300">
        {% block body %}{% endblock %}
    </main>
</div>

{% block javascripts %}
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const backdrop = document.getElementById('backdrop');
            const menuIcon = document.getElementById('menuIcon');

            sidebar.classList.toggle('-translate-x-full');
            backdrop.classList.toggle('hidden');

            if (menuIcon.classList.contains('fa-bars')) {
                menuIcon.classList.remove('fa-bars');
                menuIcon.classList.add('fa-times');
            } else {
                menuIcon.classList.remove('fa-times');
                menuIcon.classList.add('fa-bars');
            }
        }
    </script>
{% endblock %}
</body>
</html>